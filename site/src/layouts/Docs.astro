---
import Base from "./Base.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "proggy",
  description = "Markdown checklist progress reports in your terminal."
} = Astro.props;
---

<Base title={title} description={description}>
  <div class="page">
    <header class="hero">
      <div class="logo">
        <svg viewBox="0 0 32 32" class="logo-icon" aria-hidden="true">
          <rect width="32" height="32" rx="6" fill="var(--c-surface)"/>
          <rect x="7" y="8" width="8" height="3" rx="1" fill="var(--c-green)"/>
          <rect x="7" y="14" width="14" height="3" rx="1" fill="var(--c-green)"/>
          <rect x="7" y="20" width="11" height="3" rx="1" fill="var(--c-bar-empty)"/>
        </svg>
        <h1>proggy</h1>
      </div>
      <p class="tagline">Markdown checklist progress reports in your terminal.</p>
      <div class="cta">
        <code class="install">brew install nickglenn/tap/proggy</code>
        <a href="#usage" class="link-subtle">or see usage below</a>
      </div>
    </header>

    <section class="terminal-demo">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="terminal-title">proggy PROGRESS.md</span>
        </div>
        <pre class="terminal-body"><code>
  Section                                    Done  Total      %
  ──────────────────────────────────────── ────── ────── ──────
  <span class="dim">IR Core                                    71     71   100%  [████████████████████]</span>
  <span class="dim">Parser                                     23     23   100%  [████████████████████]</span>
  Backend: VM                                30     32    93%  [██████████████████░░]
  Backend: C                                 21     27    77%  [███████████████░░░░░]
  Optimization: Const Fold                   29     35    82%  [████████████████░░░░]
  Optimization: DCE                          13     18    72%  [██████████████░░░░░░]
  ──────────────────────────────────────── ────── ────── ──────
  TOTAL                                     187    206    90%  [██████████████████░░]
</code></pre>
      </div>
    </section>

    <main class="content">
      <slot />
    </main>

    <footer>
      <p>MIT License &middot; <a href="https://github.com/nickglenn/proggy">Source on GitHub</a></p>
    </footer>
  </div>
</Base>

<style>
  @import "../styles/global.css";

  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
  }

  .logo h1 {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--c-text);
  }

  .tagline {
    font-size: 1.15rem;
    color: var(--c-text-muted);
    margin-bottom: 2rem;
  }

  .cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .install {
    font-size: 0.95rem;
    padding: 0.5rem 1.25rem;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 6px;
    color: var(--c-green);
    user-select: all;
  }

  .link-subtle {
    font-size: 0.8rem;
    color: var(--c-text-muted);
  }

  .link-subtle:hover {
    color: var(--c-text);
    text-decoration: none;
  }

  .terminal-demo {
    margin: 2rem 0 3rem;
  }

  .terminal {
    border: 1px solid var(--c-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--c-surface);
    border-bottom: 1px solid var(--c-border);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--c-border);
  }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--c-text-muted);
    margin-left: auto;
    margin-right: auto;
    padding-right: 36px;
  }

  .terminal-body {
    margin: 0;
    padding: 1.25rem 1.5rem;
    font-size: 0.78rem;
    line-height: 1.5;
    border: none;
    border-radius: 0;
    background: #111113;
  }

  .terminal-body .dim {
    opacity: 0.35;
  }

  .content {
    padding-top: 1rem;
  }

  .content :global(h2) {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 3rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--c-border);
  }

  .content :global(h3) {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--c-text-muted);
    margin: 1.25rem 0 0.5rem;
  }

  .content :global(p) {
    color: var(--c-text-muted);
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .content :global(ul) {
    color: var(--c-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.25rem;
  }

  .content :global(pre) {
    margin-bottom: 1rem;
  }

  .content :global(.features) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin: 1.5rem 0 2rem;
  }

  .content :global(.feature) {
    padding: 1.25rem;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 8px;
  }

  .content :global(.feature h3) {
    margin-top: 0;
  }

  .content :global(.feature p) {
    margin-bottom: 0;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-border);
    text-align: center;
    font-size: 0.8rem;
    color: var(--c-text-muted);
  }

  @media (max-width: 600px) {
    .content :global(.features) {
      grid-template-columns: 1fr;
    }

    .logo h1 {
      font-size: 2rem;
    }

    .terminal-body {
      font-size: 0.65rem;
    }
  }
</style>
