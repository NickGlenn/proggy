---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "proggy",
  description = "Markdown checklist progress reports in your terminal."
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  @import "../styles/global.css";
</style>
